<!doctype html>
<html lang="en"><head><meta charset="utf-8"><title>Plugin Definitions</title>
<style>body{font-family:Segoe UI,Arial,sans-serif;margin:16px;background:#f8fafc;color:#0f172a}.grid{display:grid;grid-template-columns:340px 1fr;gap:12px}.panel{background:white;border:1px solid #cbd5e1;border-radius:10px;padding:12px}input,textarea{width:100%;box-sizing:border-box;padding:7px;border:1px solid #94a3b8;border-radius:7px}textarea{min-height:80px;font-family:ui-monospace,Consolas,monospace}.item{padding:8px;border:1px solid #cbd5e1;border-radius:8px;margin-bottom:8px;cursor:pointer}.row{display:grid;grid-template-columns:1fr 1fr;gap:8px}.muted{color:#64748b;font-size:12px}button{border:1px solid #94a3b8;background:white;border-radius:7px;padding:7px 10px;cursor:pointer}.primary{background:#0ea5e9;color:white;border-color:#0284c7}</style></head>
<body>{% include "_navbar.html.j2" %}<h1>Plugin Definitions</h1><p class="muted">DB-backed plugin contracts used by the workflow builder. Python implementations remain in repo files and are resolved by the existing registry.</p>
<div class="grid"><div class="panel"><button class="primary" onclick="newPlugin()">New plugin</button> <button onclick="loadAll()">Refresh</button><div id="list"></div></div>
<div class="panel"><div class="row"><label>Plugin key<input id="plugin_key"></label><label>Display name<input id="display_name"></label></div><div class="row"><label>Python module<input id="python_module"></label><label>Python class<input id="python_class"></label></div><label>Category<input id="category"></label><label>Description<textarea id="description"></textarea></label><label>Config schema JSON<textarea id="config_schema">{}</textarea></label><label>Input schema JSON<textarea id="input_schema">{}</textarea></label><label>Output schema JSON<textarea id="output_schema">{}</textarea></label><button class="primary" onclick="save()">Save</button><pre id="result" class="muted"></pre></div></div>
<script>
let items=[], current={}; const $=id=>document.getElementById(id); const pretty=v=>JSON.stringify(v,null,2);
async function api(url,opts={}){const r=await fetch(url,{headers:{'content-type':'application/json'},...opts}); const j=await r.json().catch(()=>({})); if(!r.ok) throw new Error(JSON.stringify(j)); return j;}
async function loadAll(){items=(await api('/api/plugin-definitions')).items||[]; $('list').innerHTML=items.map((p,i)=>`<div class=item onclick="edit(${i})"><b>${p.display_name}</b><div class=muted>${p.plugin_key} · ${p.category} · ${p.python_class||'contract only'}</div></div>`).join('');}
function edit(i){current=items[i]; render()} function newPlugin(){current={plugin_key:'',display_name:'',python_module:'',python_class:'',category:'general',description:'',config_schema:{type:'object',additionalProperties:true},input_schema:{type:'object'},output_schema:{type:'object'}};render()}
function render(){['plugin_key','display_name','python_module','python_class','category','description'].forEach(id=>$(id).value=current[id]||''); ['config_schema','input_schema','output_schema'].forEach(id=>$(id).value=pretty(current[id]||{}));}
async function save(){try{const body={}; ['plugin_key','display_name','python_module','python_class','category','description'].forEach(id=>body[id]=$(id).value); ['config_schema','input_schema','output_schema'].forEach(id=>body[id]=JSON.parse($(id).value||'{}')); $('result').textContent=pretty(await api('/api/plugin-definitions',{method:'POST',body:JSON.stringify(body)})); await loadAll();}catch(e){$('result').textContent=e.message}}
loadAll().then(newPlugin)
</script></body></html>