<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Discovered Target Response</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    .panel { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 12px; margin-bottom: 14px; }
    .toolbar { display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom: 12px; }
    input { padding:6px 8px; border:1px solid #94a3b8; border-radius:6px; }
    button { border:1px solid #94a3b8; background:#fff; border-radius:6px; padding:6px 10px; cursor:pointer; }
    button.primary { background:#0ea5e9; border-color:#0284c7; color:#fff; }
    pre { white-space: pre-wrap; word-break: break-word; background:#0f172a; color:#e2e8f0; padding:10px; border-radius:8px; overflow:auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; text-align: left; vertical-align: top; font-size: 12px; }
    th { background: #e2e8f0; width: 220px; }
    .muted { color: #64748b; }
    .ok { color: #166534; font-weight: 700; }
    .bad { color: #b91c1c; font-weight: 700; }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>Discovered Target Response</h1>
  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <input id="rootDomain" type="text" placeholder="root_domain">
    <input id="url" type="text" placeholder="URL" style="min-width: 480px;">
    <button class="primary" onclick="loadData()">Load</button>
    <span id="msg" class="muted"></span>
  </div>
  <div id="summary" class="panel">Enter a domain and URL.</div>
  <div class="panel">
    <h2>Metadata</h2>
    <table><tbody id="metaRows"><tr><td class="muted">No data loaded.</td></tr></tbody></table>
  </div>
  <div class="panel">
    <h2>Request Headers</h2>
    <pre id="requestHeaders">(none)</pre>
  </div>
  <div class="panel">
    <h2>Response Headers</h2>
    <pre id="responseHeaders">(none)</pre>
  </div>
  <div class="panel">
    <h2>Response Body</h2>
    <pre id="responseBody">(none)</pre>
  </div>
<script>
const TOKEN_COOKIE_NAME = "nightmare_coord_token";
function readCookie(name) {
  const needle = `${name}=`;
  const cookies = String(document.cookie || "").split(";");
  for (const part of cookies) {
    const item = part.trim();
    if (item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length));
  }
  return "";
}
function writeCookie(name, value, days) {
  const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60;
  const secure = location.protocol === "https:" ? "; Secure" : "";
  document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;
}
function deleteCookie(name) {
  const secure = location.protocol === "https:" ? "; Secure" : "";
  document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;
}
function authHeaders() {
  const token = document.getElementById("token").value.trim();
  if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30); else deleteCookie(TOKEN_COOKIE_NAME);
  return token ? { Authorization: `Bearer ${token}` } : {};
}
function esc(v) {
  return String(v ?? "").replace(/[&<>"']/g, (ch) => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[ch]));
}
function prettyHeaders(headers) {
  if (!headers || typeof headers !== "object") return "(none)";
  return Object.entries(headers).map(([k, v]) => `${k}: ${v}`).join("\n") || "(none)";
}
function decodeBody(payload) {
  const response = payload && typeof payload.response === "object" ? payload.response : {};
  const bodyBase64 = String(response.body_base64 || "");
  if (!bodyBase64) return "(empty)";
  try {
    return atob(bodyBase64);
  } catch (err) {
    return `(unable to decode body: ${err})`;
  }
}
async function loadData() {
  const rootDomain = document.getElementById("rootDomain").value.trim();
  const url = document.getElementById("url").value.trim();
  const msg = document.getElementById("msg");
  if (!rootDomain || !url) {
    msg.textContent = "root_domain and URL are required.";
    return;
  }
  msg.textContent = "Loading…";
  const qs = new URLSearchParams({ root_domain: rootDomain, url });
  const rsp = await fetch(`/api/coord/discovered-target-response?${qs.toString()}`, { headers: authHeaders(), credentials: "same-origin" });
  const payload = await rsp.json().catch(() => ({}));
  if (!rsp.ok) {
    msg.textContent = payload.error || `HTTP ${rsp.status}`;
    document.getElementById("summary").innerHTML = `<span class="bad">${esc(payload.error || "Request failed")}</span>`;
    return;
  }
  msg.textContent = "";
  const summary = payload.summary || {};
  document.getElementById("summary").innerHTML = `
    <div><strong>URL:</strong> ${esc(payload.url || "")}</div>
    <div><strong>Exists:</strong> <span class="${summary.exists_status === "exists" ? "ok" : "bad"}">${esc(summary.exists_status || "unknown")}</span></div>
    <div><strong>Reason:</strong> ${esc(summary.exists_reason || summary.probe_note || "")}</div>
  `;
  const meta = [
    ["Root Domain", payload.root_domain || ""],
    ["Captured At UTC", payload.captured_at_utc || summary.captured_at_utc || ""],
    ["Request Method", summary.request_method || ""],
    ["Response Status", summary.response_status_code ?? ""],
    ["Response URL", summary.response_url || ""],
    ["Elapsed (ms)", summary.response_elapsed_ms ?? ""],
    ["Size (bytes)", summary.response_size_bytes ?? ""],
    ["Content Type", summary.response_content_type || ""],
    ["Body Truncated", summary.body_truncated ? "yes" : "no"],
    ["Soft-404 Detected", summary.soft_404_detected ? "yes" : "no"],
    ["Soft-404 Reason", summary.soft_404_reason || ""],
    ["Evidence Path", payload.evidence_path || ""]
  ];
  document.getElementById("metaRows").innerHTML = meta.map(([k,v]) => `<tr><th>${esc(k)}</th><td>${esc(v)}</td></tr>`).join("");
  document.getElementById("requestHeaders").textContent = prettyHeaders(payload.request && payload.request.headers);
  document.getElementById("responseHeaders").textContent = prettyHeaders(payload.response && payload.response.headers);
  document.getElementById("responseBody").textContent = decodeBody(payload);
}
(function init() {
  const cookieToken = readCookie(TOKEN_COOKIE_NAME);
  if (cookieToken) document.getElementById("token").value = cookieToken;
  const params = new URLSearchParams(location.search);
  const rd = params.get("root_domain") || "";
  const url = params.get("url") || "";
  if (rd) document.getElementById("rootDomain").value = rd;
  if (url) document.getElementById("url").value = url;
  if (rd && url) loadData();
})();
</script>
</body>
</html>
