# Build context: DotNetSolution repository root (parent of this folder).
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy project files first so NuGet restore is cached when only .cs files change.
COPY Directory.Build.props NightmareV2.slnx ./
COPY src/NightmareV2.Application/NightmareV2.Application.csproj src/NightmareV2.Application/
COPY src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj src/NightmareV2.CommandCenter/
COPY src/NightmareV2.Contracts/NightmareV2.Contracts.csproj src/NightmareV2.Contracts/
COPY src/NightmareV2.Domain/NightmareV2.Domain.csproj src/NightmareV2.Domain/
COPY src/NightmareV2.Infrastructure/NightmareV2.Infrastructure.csproj src/NightmareV2.Infrastructure/
COPY src/NightmareV2.Gatekeeper/NightmareV2.Gatekeeper.csproj src/NightmareV2.Gatekeeper/
COPY src/NightmareV2.Workers.Enum/NightmareV2.Workers.Enum.csproj src/NightmareV2.Workers.Enum/
COPY src/NightmareV2.Workers.HighValue/NightmareV2.Workers.HighValue.csproj src/NightmareV2.Workers.HighValue/
COPY src/NightmareV2.Workers.PortScan/NightmareV2.Workers.PortScan.csproj src/NightmareV2.Workers.PortScan/
COPY src/NightmareV2.Workers.Spider/NightmareV2.Workers.Spider.csproj src/NightmareV2.Workers.Spider/
RUN dotnet restore "src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj"

COPY src ./src
RUN dotnet publish "src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj" \
    -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
ARG BUILD_SOURCE_STAMP=unknown
LABEL org.opencontainers.image.revision="${BUILD_SOURCE_STAMP}"
ENV NIGHTMARE_BUILD_STAMP=${BUILD_SOURCE_STAMP}
# Npgsql can dlopen Kerberos for Postgres auth negotiation; slim runtime image omits it by default.
# curl: Docker HEALTHCHECK + manual probes.
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgssapi-krb5-2 curl \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV ASPNETCORE_URLS=http://+:8080
# Avoid HTTPS redirect/HSTS when only HTTP is bound (matches compose Nightmare__ListenPlainHttp).
ENV Nightmare__ListenPlainHttp=true
EXPOSE 8080
COPY --from=build /app/publish .
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8080/health >/dev/null || exit 1
# Default process is the web app. To run the dotnet host inside this image (e.g. --info), override entrypoint:
#   docker run --rm --entrypoint dotnet <this-image> --info
ENTRYPOINT ["dotnet", "NightmareV2.CommandCenter.dll"]
