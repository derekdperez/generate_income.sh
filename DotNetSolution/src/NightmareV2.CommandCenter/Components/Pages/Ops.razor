@page "/ops"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using NightmareV2.CommandCenter.Models
@using static Microsoft.AspNetCore.Components.QuickGrid.SortDirection
@implements IDisposable
@inject HttpClient Http

<PageTitle>Operations · Nightmare v2</PageTitle>

<h1>Operations</h1>

<section class="panel">
    <h2>Data overview</h2>
    @if (_overview is null)
    {
        <p>Loading summary…</p>
    }
    else
    {
        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Total targets</div>
                <div class="stat-value">@_overview.TotalTargets</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total assets discovered</div>
                <div class="stat-value">@_overview.TotalAssetsDiscovered</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total URL assets</div>
                <div class="stat-value">@_overview.TotalUrlAssets</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">URLs from fetched pages</div>
                <div class="stat-value">@_overview.UrlsFromFetchedPages</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">URLs from scripts</div>
                <div class="stat-value">@_overview.UrlsFromScripts</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">URLs guessed via wordlist</div>
                <div class="stat-value">@_overview.UrlsGuessedWithWordlist</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Domain with most assets</div>
                <div class="stat-value small">@(_overview.TopDomainByAssets ?? "—") (@_overview.TopDomainAssetCount)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Domains with 10+ assets</div>
                <div class="stat-value">@_overview.DomainsWith10OrMoreAssets</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Domains with 10 or fewer assets</div>
                <div class="stat-value">@_overview.DomainsWith10OrFewerAssets</div>
            </div>
        </div>
    }
</section>

<section class="panel">
    <h2>Assets</h2>
    <div class="row">
        <label>Target filter</label>
        <select @bind="_targetFilter" @bind:after="ReloadAssetsAsync">
            <option value="">All targets</option>
            @foreach (var t in _targets)
            {
                <option value="@t.Id.ToString()">@t.RootDomain</option>
            }
        </select>
        <button type="button" @onclick="ReloadAllAsync">Refresh now</button>
    </div>
    <NightmareDataGrid TGridItem="AssetGridRowDto"
                       Items="FilteredAssets"
                       @bind-SearchText="_filterAssets"
                       SearchPlaceholder="Filter kind, status, raw URL, pipeline, how found…"
                       ScrollPreset="NightmareDataGridScrollPreset.Tall"
                       Virtualize="true"
                       ItemSize="40"
                       ItemKey="@(a => a.Id)"
                       OverscanCount="6"
                       HostTabIndex="@(-1)">
        <PropertyColumn Title="Discovered (UTC)" Property="@(a => a.DiscoveredAtUtc)" Format="u" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="Descending" />
        <PropertyColumn Title="Kind" Property="@(a => a.Kind)" Sortable="true" />
        <PropertyColumn Title="Status" Property="@(a => a.LifecycleStatus)" Sortable="true" />
        <PropertyColumn Title="Depth" Property="@(a => a.Depth)" Sortable="true" />
        <PropertyColumn Title="Raw" Property="@(a => a.RawValue)" Sortable="true" />
        <PropertyColumn Title="Pipeline" Property="@(a => a.DiscoveredBy)" Sortable="true" />
        <TemplateColumn Title="How found" Context="a" SortBy="@SortAssetDiscoveryContext">
            <span title="@a.DiscoveryContext">@(string.IsNullOrWhiteSpace(a.DiscoveryContext) ? "—" : a.DiscoveryContext)</span>
        </TemplateColumn>
    </NightmareDataGrid>
</section>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly List<TargetSummary> _targets = [];
    private readonly List<AssetGridRowDto> _assets = [];
    private OpsOverviewDto? _overview;
    private string _targetFilter = "";
    private string _filterAssets = "";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAllAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(2000, _pollCts.Token).ConfigureAwait(false);
                await ReloadVolatileAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // shutdown
        }
    }

    private async Task ReloadVolatileAsync()
    {
        try
        {
            var overview = await Http.GetFromJsonAsync<OpsOverviewDto>("/api/ops/overview").ConfigureAwait(false);
            if (overview is not null)
                _overview = overview;
        }
        catch
        {
            // keep last good overview
        }
    }

    private async Task ReloadAllAsync()
    {
        try
        {
            var targets = await Http.GetFromJsonAsync<List<TargetSummary>>("/api/targets").ConfigureAwait(false);
            _targets.Clear();
            if (targets is not null)
                _targets.AddRange(targets);
        }
        catch
        {
            _targets.Clear();
        }

        await ReloadAssetsAsync().ConfigureAwait(false);
        await ReloadVolatileAsync().ConfigureAwait(false);
    }

    private async Task ReloadAssetsAsync()
    {
        try
        {
            var qs = string.IsNullOrEmpty(_targetFilter) ? "?take=800" : $"?targetId={Uri.EscapeDataString(_targetFilter)}&take=800";
            var list = await Http.GetFromJsonAsync<List<AssetGridRowDto>>($"/api/assets{qs}").ConfigureAwait(false);
            _assets.Clear();
            if (list is not null)
                _assets.AddRange(list);
        }
        catch
        {
            _assets.Clear();
        }
    }

    public void Dispose() => _pollCts.Cancel();
}
