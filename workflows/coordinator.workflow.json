      "plugin_name": "nightmare_crawl_core",
      "enabled": true,
      "resume_mode": "exact",
      "preconditions": {
        "target_statuses": [
          "completed"
        ]
      },
      "retry_failed": false,
      "max_attempts": 1,
      "inputs": {},
      "outputs": {
        "artifacts": []
      },
      "parameters": {}
    },
    {
