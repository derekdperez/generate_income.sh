      "description": "Run auth0r once nightmare session data is available.",
      "category": "builtin",
      "contract_version": "1.0.0",
      "handler": "legacy_step_adapter",
      "config_schema": {
        "type": "object",
        "additionalProperties": true
      },
      "plugin_name": "auth0r",
      "enabled": true,
      "resume_mode": "exact",
      "preconditions": {
